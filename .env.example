# Copy this file to .env.local and fill in the values from your Supabase project.
# .env.local is gitignored and will NOT be committed.
#
# Supabase dashboard: Project Settings -> API
#   Project URL  -> VITE_SUPABASE_URL
#   anon public  -> VITE_SUPABASE_ANON_KEY
#
# These are SAFE to commit/expose — Supabase enforces security via Row Level
# Security policies, not key secrecy. The service_role key is the secret one.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key-here

# YouTube Data API v3 key (optional but recommended).
# Without this key, only canonical /channel/UC... URLs can be turned into
# permanent live embeds. With it, ChurchHub can resolve @handles, /c/ custom
# URLs, /user/ legacy URLs, fetch channel name + thumbnail, and detect live
# status for the "Live Now" badge.
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_YOUTUBE_API_KEY=

# Admin passcode that unlocks the "Add new church" button in the admin panel.
# Without this set, the create-church flow is hidden entirely.
VITE_ADMIN_PASSCODE=
